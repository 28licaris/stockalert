# Copy this file to .env and fill in your values. Never commit .env.
# cp .env.example .env

# -----------------------------------------------------------------------------
# Data Providers (schwab | polygon | alpaca | thinkorswim)
# -----------------------------------------------------------------------------
# Two roles, set independently:
#   STREAM_PROVIDER  — live WebSocket bars   (watchlist_service)
#   HISTORY_PROVIDER — REST backfill / deep  (backfill_service, dashboard charts)
# Either role falls back to DATA_PROVIDER when empty.
#
# Provider tradeoffs:
#   Schwab    free real-time WS + REST; 1m depth capped at 48 days
#             (5/15/30m: ~270d, daily: 20y, weekly/monthly: 20y)
#   Polygon   paid; 4+ years of 1m REST, full flat-file archive
#   Alpaca    free real-time WS but IEX-only by default; not currently used
#
# Recommended pattern: Schwab live + Polygon history.
DATA_PROVIDER=schwab
STREAM_PROVIDER=
HISTORY_PROVIDER=polygon

# Alpaca (only set if you flip STREAM_PROVIDER=alpaca)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_FEED=iex

# Polygon / Massive (when DATA_PROVIDER, STREAM_PROVIDER, or HISTORY_PROVIDER=polygon)
POLYGON_API_KEY=
POLYGON_FEED=socket.polygon.io
POLYGON_MARKET=stocks
POLYGON_SECURE_WS=true

# Polygon / Massive Flat Files (S3-compatible historical files)
POLYGON_FLATFILES_ENABLED=false
POLYGON_S3_ACCESS_KEY_ID=
POLYGON_S3_SECRET_ACCESS_KEY=
POLYGON_S3_ENDPOINT=https://files.massive.com
POLYGON_S3_BUCKET=flatfiles

# -----------------------------------------------------------------------------
# Stock Lake (your own S3 data lake) — see docs/data_platform_plan.md for layout.
# AWS_* may be left empty to fall through to the default boto3 credential chain
# (env vars, ~/.aws/credentials, IAM role, etc.). On EC2/ECS you only need to
# set STOCK_LAKE_BUCKET.
# -----------------------------------------------------------------------------
STOCK_LAKE_BUCKET=
STOCK_LAKE_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
# -----------------------------------------------------------------------------
# Nightly bronze ingest schedules (per provider, identical shape).
# Both run as asyncio background tasks from FastAPI startup. Gated by their
# *_NIGHTLY_ENABLED flag + valid credentials + STOCK_LAKE_BUCKET set.
# -----------------------------------------------------------------------------

# *_NIGHTLY_SYMBOLS spec strings (G1 dynamic universe):
#   "seed"          → SEED_SYMBOLS only (the curated 100, static)
#   "active"        → stream_universe symbols (the canonical "what's
#                     our hot universe?" table per
#                     docs/standards/data/symbol_lifecycle.md).
#                     Adding a symbol via the cockpit Stream Service
#                     page (or POST /api/v1/stream) automatically
#                     grows the universe — no separate "promote" step.
#   "seed"          → legacy SEED_SYMBOLS (static curated 100). Kept
#                     for operator scripts; new code paths use "active".
#   "AAPL,NVDA,..." → explicit comma-separated list (operator override)
#   "all" / "*"     → (Polygon only) whole-market via flat-files
#
# LOCKED operational defaults (per symbol_lifecycle.md):
#   POLYGON_NIGHTLY_SYMBOLS=all      ← whole market (flat-files cover everything)
#   SCHWAB_NIGHTLY_SYMBOLS=active    ← stream_universe (Schwab REST is rate-limited)
#   SILVER_OHLCV_BUILD_SYMBOLS=active

# Polygon flat-files → bronze.polygon_minute.
# 07:00 UTC = midnight Arizona; after Polygon's flat file is ready.
POLYGON_NIGHTLY_ENABLED=false
POLYGON_NIGHTLY_RUN_HOUR_UTC=7
POLYGON_NIGHTLY_SYMBOLS=all
POLYGON_NIGHTLY_KIND=minute

# Schwab REST pricehistory → bronze.schwab_minute. Requires SCHWAB_* creds below.
# 22:00 UTC = 3 PM Arizona; ~30 min after NYSE 4 PM ET close.
SCHWAB_NIGHTLY_ENABLED=false
SCHWAB_NIGHTLY_RUN_HOUR_UTC=22
SCHWAB_NIGHTLY_SYMBOLS=active

# Nightly silver OHLCV build (TA-5.1.6) — bronze.{provider}_minute →
# silver.ohlcv_1m + silver.bar_quality.  Runs AFTER both upstream
# nightlies above so the bronze tables for yesterday are settled.
# 23:00 UTC = 1h after the Schwab nightly's default 22:00 UTC.
SILVER_OHLCV_BUILD_ENABLED=false
SILVER_OHLCV_BUILD_RUN_HOUR_UTC=23
SILVER_OHLCV_BUILD_SYMBOLS=active

# TA-5.3.3 — silver-derived add_members flow.
# When `true`, watchlist_service.add_members uses the new unified
# silver-derived path per docs/streaming_universe_model.md:
#   1. silver_to_ch_backfill (silver → CH, 730d)
#   2. schwab_rest_tip_fill  (silver watermark → live, ≤48d)
# When `false` (default), uses the legacy provider-REST-direct-to-CH
# path (Path ②, scheduled for removal in TA-5.5).
# Flip this to true AFTER TA-5.1.7 operator backfill is verified.
SILVER_DERIVED_ADD_MEMBERS_ENABLED=false

# -----------------------------------------------------------------------------
# Iceberg catalog (AWS Glue). See docs/data_platform_plan.md.
# Warehouse path: s3://${STOCK_LAKE_BUCKET}/${ICEBERG_WAREHOUSE_PREFIX}/
# -----------------------------------------------------------------------------
ICEBERG_CATALOG_NAME=stock_lake
ICEBERG_GLUE_DATABASE=stock_lake
ICEBERG_WAREHOUSE_PREFIX=iceberg

# Architecture v2 — equities namespace (Gate 1).
# Tables created by app/services/equities/tables.py live in this Glue DB.
# See docs/architecture_v2/08_decisions.md#gate-1.
ICEBERG_EQUITIES_GLUE_DATABASE=equities

# Schwab / Think or Swim (when DATA_PROVIDER=schwab or thinkorswim)
# Get refresh token once via: poetry run python scripts/schwab_get_refresh_token.py
JOURNAL_ENABLED=true
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REFRESH_TOKEN=
# For get-refresh-token script: use your ngrok HTTPS URL + /callback (e.g. https://abc.ngrok-free.app/callback). Run: ngrok http 8765
SCHWAB_CALLBACK_URL=
SCHWAB_BASE_URL=https://api.schwabapi.com

# -----------------------------------------------------------------------------
# ClickHouse (time-series)
# -----------------------------------------------------------------------------
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=stocks
# Optional tag on OHLCV rows; defaults to DATA_PROVIDER if empty
DATA_SOURCE_TAG=

# -----------------------------------------------------------------------------
# Technical Analysis / Divergence
# -----------------------------------------------------------------------------
PIVOT_K=4
LOOKBACK_BARS=80
EMA_PERIOD=50
USE_TREND_FILTER=false
MIN_PRICE_CHANGE_PCT=0.003
MIN_INDICATOR_CHANGE_PCT=0.02
MIN_PIVOT_SEPARATION=12

# -----------------------------------------------------------------------------
# Historical / Cache
# -----------------------------------------------------------------------------
MONITOR_PRELOAD_BARS=200
MONITOR_PRELOAD_DAYS=5
BACKFILL_DEFAULT_DAYS=30
MAX_BARS_PER_REQUEST=10000
FETCH_SAFETY_MARGIN=1.3
DATA_SUFFICIENCY_THRESHOLD=0.8
USE_PARQUET_CACHE=false
PARQUET_CACHE_DIR=./data/parquet

# -----------------------------------------------------------------------------
# Assistant (cockpit copilot) — see docs/assistant_plan.md.
# The Anthropic SDK auto-reads ANTHROPIC_API_KEY from the environment;
# both this service and the trading LLMAgent strategy share the same key.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Alerts / Monitoring
# -----------------------------------------------------------------------------
ALERT_WEBHOOK_URL=
ALERT_MIN_SEPARATION_MIN=15
HEARTBEAT_INTERVAL_SECONDS=600
MAX_IDLE_TIME_SECONDS=3600
