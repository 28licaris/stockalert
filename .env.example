# Copy this file to .env and fill in your values. Never commit .env.
# cp .env.example .env

# -----------------------------------------------------------------------------
# Data Providers (schwab | polygon | alpaca | thinkorswim)
# -----------------------------------------------------------------------------
# Two roles, set independently:
#   STREAM_PROVIDER  — live WebSocket bars   (watchlist_service)
#   HISTORY_PROVIDER — REST backfill / deep  (backfill_service, dashboard charts)
# Either role falls back to DATA_PROVIDER when empty.
#
# Provider tradeoffs:
#   Schwab    free real-time WS + REST; 1m depth capped at 48 days
#             (5/15/30m: ~270d, daily: 20y, weekly/monthly: 20y)
#   Polygon   paid; 4+ years of 1m REST, full flat-file archive
#   Alpaca    free real-time WS but IEX-only by default; not currently used
#
# Recommended pattern: Schwab live + Polygon history.
DATA_PROVIDER=schwab
STREAM_PROVIDER=
HISTORY_PROVIDER=polygon

# Alpaca (only set if you flip STREAM_PROVIDER=alpaca)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_FEED=iex

# Polygon / Massive (when DATA_PROVIDER, STREAM_PROVIDER, or HISTORY_PROVIDER=polygon)
POLYGON_API_KEY=
POLYGON_FEED=socket.polygon.io
POLYGON_MARKET=stocks
POLYGON_SECURE_WS=true

# Polygon / Massive Flat Files (S3-compatible historical files)
POLYGON_FLATFILES_ENABLED=false
POLYGON_S3_ACCESS_KEY_ID=
POLYGON_S3_SECRET_ACCESS_KEY=
POLYGON_S3_ENDPOINT=https://files.massive.com
POLYGON_S3_BUCKET=flatfiles

# -----------------------------------------------------------------------------
# Stock Lake (your own S3 data lake) — see docs/data_platform_plan.md for layout.
# AWS_* may be left empty to fall through to the default boto3 credential chain
# (env vars, ~/.aws/credentials, IAM role, etc.). On EC2/ECS you only need to
# set STOCK_LAKE_BUCKET.
# -----------------------------------------------------------------------------
STOCK_LAKE_BUCKET=
STOCK_LAKE_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
# -----------------------------------------------------------------------------
# Nightly bronze ingest schedules (per provider, identical shape).
# Both run as asyncio background tasks from FastAPI startup. Gated by their
# *_NIGHTLY_ENABLED flag + valid credentials + STOCK_LAKE_BUCKET set.
# -----------------------------------------------------------------------------

# *_NIGHTLY_SYMBOLS spec strings (G1 dynamic universe):
#   "active"        → stream_universe symbols (the canonical "what's
#                     our hot universe?" table per
#                     docs/standards/data/symbol_lifecycle.md).
#                     Adding a symbol via the cockpit Stream Service
#                     page (or POST /api/v1/stream) automatically
#                     grows the universe — no separate "promote" step.
#   "AAPL,NVDA,..." → explicit comma-separated list (operator override)
#   "all" / "*"     → (Polygon only) whole-market via flat-files
#
# LOCKED operational defaults (per symbol_lifecycle.md):
#   POLYGON_NIGHTLY_SYMBOLS=all      ← whole market (flat-files cover everything)
#   SCHWAB_NIGHTLY_SYMBOLS=active    ← stream_universe (Schwab REST is rate-limited)

# Nightly lake writers — DEFAULT ON (production-grade freshness; the lake
# self-heals nightly via per-job auto-catchup). Each ALSO requires a
# non-empty STOCK_LAKE_BUCKET + valid provider creds, so a dev/CI box
# without them is a clean no-op. Set a flag to false to opt that writer out.

# Polygon flat-files → equities.polygon_raw (CV7).
# 07:00 UTC = midnight Arizona; after Polygon's flat file is ready.
POLYGON_NIGHTLY_ENABLED=true
POLYGON_NIGHTLY_RUN_HOUR_UTC=7
POLYGON_NIGHTLY_SYMBOLS=all
POLYGON_NIGHTLY_KIND=minute

# Schwab REST pricehistory → equities.schwab_universe (CV8). Requires SCHWAB_* creds below.
# 22:00 UTC = 3 PM Arizona; ~30 min after NYSE 4 PM ET close.
SCHWAB_NIGHTLY_ENABLED=true
SCHWAB_NIGHTLY_RUN_HOUR_UTC=22
SCHWAB_NIGHTLY_SYMBOLS=active

# Schwab REST pricehistory → futures.schwab_futures (F3). Continuous roots
# (/ES, /MES, …). Same shape/creds as the equities nightly, toggled apart.
# "active" = stocks.futures_universe (∪ FUTURES_SEED_ROOTS fallback); "seed"
# = the static seed roots only.
FUTURES_NIGHTLY_ENABLED=true
FUTURES_NIGHTLY_RUN_HOUR_UTC=22
FUTURES_NIGHTLY_SYMBOLS=active

# Schwab REST option-chain snapshots → options.* Iceberg tables. OFF by
# default because this can create steady provider/API load during market hours.
# Symbols: "active", "watchlist:<name>", or explicit CSV like "AAPL,NVDA".
OPTIONS_SNAPSHOT_ENABLED=false
OPTIONS_SNAPSHOT_INTERVAL_SECONDS=300
OPTIONS_SNAPSHOT_SYMBOLS=active
OPTIONS_SNAPSHOT_STRIKE_COUNT=20
OPTIONS_SNAPSHOT_CONTRACT_TYPE=ALL

# Polygon flat-file → futures.polygon_raw → futures.polygon_continuous (heavy
# per-root rebuild). 21:00 UTC — Polygon finalizes a day's files ~11:00 ET.
FUTURES_POLYGON_NIGHTLY_ENABLED=true
FUTURES_POLYGON_NIGHTLY_RUN_HOUR_UTC=21

# Lake-warmup add_members flow (v2 / CV12 + CV15).
# When `true`, stream_service.add fires the lake-warmup chain in
# parallel on newly-added symbols:
#   1. tip_fill (Schwab REST → equities.schwab_universe + CH; 48d)
#   2. lake_to_ch_backfill (equities.polygon_adjusted → CH; 730d)
# Target latency <10s end-to-end.
# When `false` (default), uses the legacy provider-REST-direct-to-CH
# path. Flip to `true` once the Phase 1 cutover is verified in prod
# (CV10' Athena bulk-import + CV6 polygon_adjustment_job whole-market
# have both run successfully).
LAKE_WARMUP_ENABLED=false

# Hotload-on-add (fast recent tier). When true, adding a symbol seeds the
# last SYMBOL_HOTLOAD_DAYS of 1m bars into the CH hot cache so the chart
# paints quickly (provider-agnostic quick backfill; Schwab by default).
# false = pure "stream from now" (subscribe live, no backfill). 30 days
# is sized for a <5s first paint; lower it (e.g. 7) if needed.
SYMBOL_HOTLOAD_ENABLED=true
SYMBOL_HOTLOAD_DAYS=30

# Read-path gap-fill (edge case). When a requested symbol/window isn't in
# CH and the lake can't cover it either (brand-new/cold symbol), fall to a
# provider REST fill (Schwab tip-fill -> lake + CH) so the chart self-heals.
# Non-blocking, idempotent. Nightly jobs own the steady state. Equities only.
SYMBOL_GAPFILL_ENABLED=true

# -----------------------------------------------------------------------------
# Iceberg catalog (AWS Glue). See docs/data_platform_plan.md.
# Warehouse path: s3://${STOCK_LAKE_BUCKET}/${ICEBERG_WAREHOUSE_PREFIX}/
# -----------------------------------------------------------------------------
ICEBERG_CATALOG_NAME=stock_lake
ICEBERG_GLUE_DATABASE=stock_lake
ICEBERG_WAREHOUSE_PREFIX=iceberg

# Architecture v2 — equities namespace (Gate 1).
# Tables created by app/services/equities/tables.py live in this Glue DB.
# See docs/architecture_v2/08_decisions.md#gate-1.
ICEBERG_EQUITIES_GLUE_DATABASE=equities
ICEBERG_FUTURES_GLUE_DATABASE=futures
ICEBERG_OPTIONS_GLUE_DATABASE=options

# Schwab / Think or Swim (when DATA_PROVIDER=schwab or thinkorswim)
# Get refresh token once via: poetry run python scripts/schwab_get_refresh_token.py
JOURNAL_ENABLED=true
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REFRESH_TOKEN=
# For get-refresh-token script: use your ngrok HTTPS URL + /callback (e.g. https://abc.ngrok-free.app/callback). Run: ngrok http 8765
SCHWAB_CALLBACK_URL=
SCHWAB_BASE_URL=https://api.schwabapi.com

# -----------------------------------------------------------------------------
# ClickHouse (time-series)
# -----------------------------------------------------------------------------
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=stocks
# Optional tag on OHLCV rows; defaults to DATA_PROVIDER if empty
DATA_SOURCE_TAG=

# -----------------------------------------------------------------------------
# Customer identity PostgreSQL (accounts/sessions/billing; never market data).
# Lightweight local container: docker compose --profile identity up -d postgres
# Production injects an RDS URL from the approved secret store.
# -----------------------------------------------------------------------------
IDENTITY_DATABASE_URL=postgresql+psycopg://stockalert:stockalert_dev@localhost:5432/stockalert_identity

# Cognito browser authentication. Keep disabled until the user pool, app client,
# callback URL, and PostgreSQL migrations are configured. Client secret is
# optional for public PKCE clients; confidential server clients may set it.
AUTH_ENABLED=false
COGNITO_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com
COGNITO_ISSUER_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_EXAMPLE
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_REDIRECT_URI=http://localhost:8000/auth/callback
COGNITO_LOGOUT_URI=http://localhost:8000/app/login
AUTH_SESSION_HOURS=8
AUTH_LOGIN_TRANSACTION_MINUTES=10
AUTH_COOKIE_NAME=stockalert_session
AUTH_CSRF_COOKIE_NAME=stockalert_csrf
# Local HTTP only. Production must set true and serve HTTPS.
AUTH_COOKIE_SECURE=false
AUTH_PROVIDER_TOKEN_CIPHER=local
# Production: set cipher=kms and provide a customer-managed KMS key ARN.
AUTH_PROVIDER_TOKEN_KMS_KEY_ID=

# -----------------------------------------------------------------------------
# Stripe billing (customer subscriptions). Leave STRIPE_SECRET_KEY empty to
# disable — the billing API then returns 503 "billing_not_configured" instead
# of failing. Requires IDENTITY_DATABASE_URL (subscription state lives there).
# STRIPE_WEBHOOK_SECRET is the signing secret for the /webhook endpoint.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
BILLING_TRIAL_DAYS=0
BILLING_RETURN_URL=http://localhost:8000/app/settings

# -----------------------------------------------------------------------------
# Technical Analysis / Divergence
# -----------------------------------------------------------------------------
PIVOT_K=4
LOOKBACK_BARS=80
EMA_PERIOD=50
USE_TREND_FILTER=false
MIN_PRICE_CHANGE_PCT=0.003
MIN_INDICATOR_CHANGE_PCT=0.02
MIN_PIVOT_SEPARATION=12

# -----------------------------------------------------------------------------
# Historical / Cache
# -----------------------------------------------------------------------------
MONITOR_PRELOAD_BARS=200
MONITOR_PRELOAD_DAYS=5
MAX_BARS_PER_REQUEST=10000
FETCH_SAFETY_MARGIN=1.3
DATA_SUFFICIENCY_THRESHOLD=0.8
USE_PARQUET_CACHE=false
PARQUET_CACHE_DIR=./data/parquet

# -----------------------------------------------------------------------------
# Assistant (cockpit copilot) — see docs/assistant_plan.md.
# The Anthropic SDK auto-reads ANTHROPIC_API_KEY from the environment;
# both this service and the trading LLMAgent strategy share the same key.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Alerts / Monitoring
# -----------------------------------------------------------------------------
ALERT_WEBHOOK_URL=
ALERT_MIN_SEPARATION_MIN=15
HEARTBEAT_INTERVAL_SECONDS=600
MAX_IDLE_TIME_SECONDS=3600
