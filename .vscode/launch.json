{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Start FastAPI Server",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main_api:app",
                "--reload",
                "--host", "0.0.0.0",
                "--port", "8000"
            ],
            "jinja": true,
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/stockalert"
            },
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/stockalert"
        },
        {
            "name": "Detect Divergence: SPY (30 days, RSI, Hidden Bullish)",
            "type": "debugpy",
            "request": "launch",
            "module": "app.detect_divergence",
            "args": [
                "--tickers", "SPY",
                "--days", "30",
                "--indicator", "rsi",
                "--signal-type", "hidden_bullish_divergence"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/stockalert",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/stockalert"
            },
            "justMyCode": false
        },
        {
            "name": "Detect Divergence: Multiple Tickers (7 days)",
            "type": "debugpy",
            "request": "launch",
            "module": "app.detect_divergence",
            "args": [
                "--tickers", "SPY", "QQQ", "AAPL",
                "--days", "7",
                "--indicator", "rsi",
                "--signal-type", "hidden_bullish_divergence"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/stockalert",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/stockalert"
            },
            "justMyCode": false
        },
        {
            "name": "Test: Historical Data",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tests/test_historical.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Test: Live Stream",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tests/test_livestream.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Test: Database",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${workspaceFolder}/tests/test_database_alert.py",
                "-v",
                "-s"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Test: Indicators",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${workspaceFolder}/tests/test_indicators.py",
                "-v",
                "-s"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Test: Alert Flow",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${workspaceFolder}/tests/test_alert_flow.py",
                "-v",
                "-s"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Test: WebSocket",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${workspaceFolder}/tests/test_websocket.py",
                "-v",
                "-s"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Test: Schwab Provider",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${workspaceFolder}/tests/test_schwab_provider.py",
                "-v",
                "-s"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Test: Current File (pytest)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}",
                "-v",
                "-s"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Run All Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${workspaceFolder}/tests",
                "-v",
                "-s"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}"
        }
    ]
}