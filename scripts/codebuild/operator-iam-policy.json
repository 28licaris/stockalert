{
    "Version": "2012-10-17",
    "_metadata": {
        "description": "Operator-side IAM policy for triggering + monitoring the silver-build CodeBuild project. Attach to the `stock-lake-ingest` IAM user so the operator (or an agent acting as the operator) can kick off builds, poll status, and tail logs WITHOUT giving global CodeBuild access. All resources are scoped to the specific project + log group.",
        "attach_to": "iam user: stock-lake-ingest",
        "scope": "READ + start/stop of sockalert-silver-full-backfill only",
        "intentionally_excluded": "CreateProject, UpdateProject, DeleteProject — those are admin-level and require Console access. List perms scoped to the specific project so the user can't enumerate other projects in the account.",
        "created": "2026-05-18",
        "created_for": "TA-5.1.7 operator validation: agent triggers CodeBuild silver --full + polls + reads result.json"
    },
    "Statement": [
        {
            "Sid": "StartAndMonitorSilverBuildProject",
            "Effect": "Allow",
            "Action": [
                "codebuild:StartBuild",
                "codebuild:StopBuild",
                "codebuild:BatchGetBuilds",
                "codebuild:BatchGetProjects",
                "codebuild:ListBuildsForProject"
            ],
            "Resource": [
                "arn:aws:codebuild:us-east-1:562741918372:project/sockalert-silver-full-backfill",
                "arn:aws:codebuild:us-east-1:562741918372:build/sockalert-silver-full-backfill:*"
            ]
        },
        {
            "Sid": "ReadBuildLogs",
            "Effect": "Allow",
            "Action": [
                "logs:GetLogEvents",
                "logs:FilterLogEvents",
                "logs:DescribeLogStreams",
                "logs:DescribeLogGroups"
            ],
            "Resource": [
                "arn:aws:logs:us-east-1:562741918372:log-group:/aws/codebuild/sockalert-silver-full-backfill",
                "arn:aws:logs:us-east-1:562741918372:log-group:/aws/codebuild/sockalert-silver-full-backfill:*"
            ]
        },
        {
            "Sid": "ListBuildReportsInS3",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::stock-lake-562741918372-us-east-1-an",
                "arn:aws:s3:::stock-lake-562741918372-us-east-1-an/silver_build_reports/*"
            ]
        }
    ]
}
